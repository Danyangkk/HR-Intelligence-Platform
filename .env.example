# Application
APP_ENV=development
SECRET_KEY=change-me-in-production
API_PREFIX=/api/v1

# Database (docker-compose defaults)
DATABASE_URL=postgresql+asyncpg://hr:hr_secret@localhost:5432/hr_agent
DATABASE_URL_SYNC=postgresql+psycopg://hr:hr_secret@localhost:5432/hr_agent

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# MinIO (S3-compatible object storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=hr-documents
MINIO_SECURE=false

# DashScope (Qwen LLM / Embedding / Rerank)
DASHSCOPE_API_KEY=
DASHSCOPE_CHAT_MODEL=qwen-plus

# Feishu Open Platform
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# 飞书多维表格（Bitable）— 11 张同步表
# URL: https://xxx.feishu.cn/base/{APP_TOKEN}?table={TABLE_ID}
FEISHU_BITABLE_APP_TOKEN=
# l3-2-1-1 员工档案
FEISHU_BITABLE_PROFILE_TABLE_ID=
# l3-2-1-2 任职信息
FEISHU_BITABLE_POSITION_TABLE_ID=
# l3-2-1-4 花名册
FEISHU_BITABLE_ROSTER_TABLE_ID=
# l3-2-2-1 请假记录
FEISHU_BITABLE_LEAVE_TABLE_ID=
# l3-2-2-2 出差记录
FEISHU_BITABLE_TRAVEL_TABLE_ID=
# l3-2-2-3 外出记录
FEISHU_BITABLE_OUTGOING_TABLE_ID=
# l3-2-2-4 加班记录
FEISHU_BITABLE_OVERTIME_TABLE_ID=
# l3-2-2-5 门禁打卡
FEISHU_BITABLE_ACCESS_ATTENDANCE_TABLE_ID=
# l3-2-2-6 飞书打卡
FEISHU_BITABLE_FEISHU_ATTENDANCE_TABLE_ID=
# l3-2-2-7 考勤汇总
FEISHU_BITABLE_ATTENDANCE_SUMMARY_TABLE_ID=
# l3-2-3-1 异动记录
FEISHU_BITABLE_CHANGE_TABLE_ID=
# true=未配 table_id 时用 demo 数据；生产建议 false
FEISHU_SYNC_DEMO_FALLBACK=true

# JWT test accounts (MVP)
JWT_EXPIRE_MINUTES=1440
