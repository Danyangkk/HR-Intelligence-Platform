# Docker Compose runtime config — copied to backend/.env on container start.
# Committed placeholders only; put real secrets in backend/.env.local (gitignored).

APP_ENV=development
SECRET_KEY=change-me-in-production
API_PREFIX=/api/v1

DATABASE_URL=postgresql+asyncpg://hr:hr_secret@postgres:5432/hr_agent
DATABASE_URL_SYNC=postgresql+psycopg://hr:hr_secret@postgres:5432/hr_agent

REDIS_URL=redis://redis:6379/0

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=hr-documents
MINIO_SECURE=false

DASHSCOPE_API_KEY=
DASHSCOPE_CHAT_MODEL=qwen-plus

FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

JWT_EXPIRE_MINUTES=1440
