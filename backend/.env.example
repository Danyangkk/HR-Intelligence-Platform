# Application
APP_ENV=development
SECRET_KEY=change-me-in-production
API_PREFIX=/api/v1

# Database (docker-compose defaults)
DATABASE_URL=postgresql+asyncpg://hr:hr_secret@localhost:5432/hr_agent
DATABASE_URL_SYNC=postgresql+psycopg://hr:hr_secret@localhost:5432/hr_agent

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# MinIO (S3-compatible object storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=hr-documents
MINIO_SECURE=false

# DashScope (Qwen LLM / Embedding / Rerank) — required from P2 RAG onward
DASHSCOPE_API_KEY=

# Feishu Open Platform — required from P3 sync onward
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# JWT test accounts (MVP)
JWT_EXPIRE_MINUTES=1440
