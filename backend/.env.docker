# Docker Compose runtime — entrypoint copies to backend/.env on container start.
# Demo placeholders only (safe to commit). Put real secrets in backend/.env.local (gitignored).

APP_ENV=development
SECRET_KEY=change-me-in-production
API_PREFIX=/api/v1

DATABASE_URL=postgresql+asyncpg://hr:hr_secret@postgres:5432/hr_agent
DATABASE_URL_SYNC=postgresql+psycopg://hr:hr_secret@postgres:5432/hr_agent

REDIS_URL=redis://redis:6379/0

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=hr-documents
MINIO_SECURE=false

DASHSCOPE_API_KEY=
DASHSCOPE_CHAT_MODEL=qwen-plus

FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_PROFILE_TABLE_ID=
FEISHU_BITABLE_POSITION_TABLE_ID=
FEISHU_BITABLE_ROSTER_TABLE_ID=
FEISHU_BITABLE_LEAVE_TABLE_ID=
FEISHU_BITABLE_TRAVEL_TABLE_ID=
FEISHU_BITABLE_OUTGOING_TABLE_ID=
FEISHU_BITABLE_OVERTIME_TABLE_ID=
FEISHU_BITABLE_ACCESS_ATTENDANCE_TABLE_ID=
FEISHU_BITABLE_FEISHU_ATTENDANCE_TABLE_ID=
FEISHU_BITABLE_ATTENDANCE_SUMMARY_TABLE_ID=
FEISHU_BITABLE_CHANGE_TABLE_ID=
FEISHU_SYNC_DEMO_FALLBACK=true

JWT_EXPIRE_MINUTES=1440
